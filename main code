class Projectile:
    def __init__(self, x, y, angle, stage_type=1):
        self.size = 20
        self.x = x - self.size // 2
        self.y = y
        self.stage_type = stage_type
        
        if self.stage_type == 3:
            self.base_speed = 13.0 # LASER IS TWICE AS FAST
        else:
            self.base_speed = 6.5  
            
        self.vx = self.base_speed * math.cos(angle)
        self.vy = self.base_speed * math.sin(angle)

    def update(self, scroll_speed, world_change):
        self.x += self.vx
        self.y += self.vy
        self.y += scroll_speed
        if Y <= 400 and world_change < 0:
            self.y -= world_change

    def draw(self, surface):
        if self.stage_type == 3:
            # GLOWING LASER VISUAL
            pygame.draw.rect(surface, heavenly_gold, (self.x, self.y, 6, 35))
            pygame.draw.rect(surface, heavenly_blue, (self.x + 1, self.y + 1, 4, 33))
        elif self.stage_type == 2:
            surface.blit(projectile_stage2_img, (self.x, self.y))
        else:
            surface.blit(projectile_stage1_img, (self.x, self.y))


def check_collision(rect_list, jump):
    global X, Y, y_change, is_crouching, crouch_timer, is_boosting, booster_timer, platforms
   
    if is_boosting or is_crouching:
        return jump

    fall_margin = max(10, y_change + 2)
    player_feet_y = Y + 100
    player_feet = pygame.Rect(X + 40, player_feet_y - fall_margin, 10, fall_margin)
   
    for i in range(len(rect_list)):
        if i < len(platforms) and platforms[i][4] == "intact":
            target_landing_surface = platforms[i][1] + 5
           
            if rect_list[i].colliderect(player_feet) and not jump and y_change > 0:
                if (player_feet_y - y_change) <= target_landing_surface + 5:
                    if len(platforms[i]) > 5 and platforms[i][5] != -1:
                        booster_x = platforms[i][0] + platforms[i][5]
                        booster_y = target_landing_surface - BOOSTER_H
                        booster_rect = pygame.Rect(booster_x, booster_y, BOOSTER_W, BOOSTER_H)
                       
                        if player_feet.colliderect(booster_rect):
                            is_boosting = True
                            booster_timer = BOOSTER_DURATION
                            platforms[i][5] = -1  
                            break

                    Y = target_landing_surface - 50
                    y_change = 0
                    is_crouching = True
                    crouch_timer = CROUCH_DURATION
                    break
    return jump


def update_player(y_position):
    global jump_height, gravity, y_change, jump, score, player_speed, is_crouching, crouch_timer, is_boosting, booster_timer
   
    # PHYSICS STAGE 3 (150+ pts)
    if score >= 150:
        jump_height = 20.0
        gravity = 0.58
        player_speed = 11
    # PHYSICS STAGE 2 (70+ pts)
    elif score >= 70:
        jump_height = 16.5  
        gravity = 0.46    
        player_speed = 7  
    else:
        jump_height = 15.5
        gravity = 0.42
        player_speed = 6
   
    if is_boosting:
        y_change = -booster_speed
        booster_timer -= 1
        if booster_timer % 10 == 0:
            score += 1
        if booster_timer <= 0:
            is_boosting = False
            y_change = 0
        y_position += y_change
        return y_position

    if is_crouching:
        crouch_timer -= 1
        if crouch_timer <= 0:
            is_crouching = False
            jump = True
        else:
            return y_position
           
    if jump:
        y_change = -jump_height
        jump = False
       
    y_position += y_change  
    y_change += gravity
    return y_position
 

def update_platforms(platforms_list, y_position, change):
    global score  

    if score >= 150:
        auto_scroll_speed = 3
    elif score >= 70:
        auto_scroll_speed = 2
    else:
        auto_scroll_speed = 1

    for platform in platforms_list:
        platform[1] += auto_scroll_speed

    if y_position <= 400 and change < 0:
        for platform in platforms_list:
            platform[1] -= change

    if len(platforms_list) > 0:
        highest_y = min(platform[1] for platform in platforms_list)
    else:
        highest_y = 0

    for i in range(len(platforms_list)):
        if platforms_list[i][1] > height:
            if score >= 150:
                new_y = highest_y - random.randint(150, 190)
            elif score >= 70:
                new_y = highest_y - random.randint(180, 220)
            elif 30 <= score < 70:
                new_y = highest_y - random.randint(100, 150)
            else:
                new_y = highest_y - random.randint(200, 250)

            new_x = random.randint(0, width - PLATFORM_W)
            booster_state = random.randint(0, PLATFORM_W - BOOSTER_W) if random.random() < 0.20 else -1
           
            platforms_list[i] = [new_x, new_y, PLATFORM_W, PLATFORM_H, "intact", booster_state]
            highest_y = new_y
            score += 1  

    return platforms_list     


def draw_button(text, x, y, w, h, normal_color, hover_color):
    mouse = pygame.mouse.get_pos()
    click = pygame.mouse.get_pressed()
   
    if x < mouse[0] < x + w and y < mouse[1] < y + h:
        pygame.draw.rect(screen, hover_color, (x, y, w, h), border_radius=10)
        if click[0] == 1:
            return True
    else:
        pygame.draw.rect(screen, normal_color, (x, y, w, h), border_radius=10)
       
    text_surf = button_font.render(text, True, white)
    text_rect = text_surf.get_rect(center=((x + w/2), (y + h/2)))
    screen.blit(text_surf, text_rect)
    return False


