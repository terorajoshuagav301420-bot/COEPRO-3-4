    projectiles_cleared_at_70 = False
    projectiles_cleared_at_150 = False
    is_crouching = False
    crouch_timer = 0
    is_boosting = False
    booster_timer = 0
    boss_enemy = Enemy()
    stage2_enemy = Stage2Enemy()
    stage3_enemy = Stage3Enemy()
    falling_blocks.clear()
    stage_alert.reset()


def save_game_session():
    with open("save_file.txt", "w") as f:
        f.write(f"player_x:{X}\n")
        f.write(f"player_y:{Y}\n")
        f.write(f"score:{score}\n")
        f.write(f"y_change:{y_change}\n")
        f.write(f"x_change:{x_change}\n")
        f.write(f"is_boosting:{int(is_boosting)}\n")
        f.write(f"booster_timer:{booster_timer}\n")
        f.write(f"is_crouching:{int(is_crouching)}\n")
        f.write(f"crouch_timer:{crouch_timer}\n")
        f.write(f"p_cleared_70:{int(projectiles_cleared_at_70)}\n")
        f.write(f"p_cleared_150:{int(projectiles_cleared_at_150)}\n")
        f.write(f"stage2_trig:{int(stage_alert.triggered_stage2)}\n")
        f.write(f"stage3_trig:{int(stage_alert.triggered_stage3)}\n")
       
        for p in platforms:
            f.write(f"plat:{p[0]},{p[1]},{p[2]},{p[3]},{p[4]},{p[5]}\n")


def load_game_session():
    global X, Y, score, platforms, y_change, x_change, is_boosting, booster_timer, is_crouching, crouch_timer, projectiles_cleared_at_70, projectiles_cleared_at_150, falling_blocks, boss_enemy, stage2_enemy, stage3_enemy, stage_alert
   
    if not os.path.exists("save_file.txt"):
        return False
       
    loaded_platforms = []
   
    try:
        with open("save_file.txt", "r") as f:
            for line in f:
                line = line.strip()
                if not line or ":" not in line:
                    continue
               
                key, val = line.split(":", 1)
               
                if key == "player_x": X = float(val)
                elif key == "player_y": Y = float(val)
                elif key == "score": score = int(val)
                elif key == "y_change": y_change = float(val)
                elif key == "x_change": x_change = float(val)
                elif key == "is_boosting": is_boosting = bool(int(val))
                elif key == "booster_timer": booster_timer = int(val)
                elif key == "is_crouching": is_crouching = bool(int(val))
                elif key == "crouch_timer": crouch_timer = int(val)
                elif key in ["p_cleared_100", "p_cleared_70"]: projectiles_cleared_at_70 = bool(int(val))
                elif key in ["p_cleared_170", "p_cleared_150"]: projectiles_cleared_at_150 = bool(int(val))
                elif key == "stage2_trig": stage_alert.triggered_stage2 = bool(int(val))
                elif key == "stage3_trig": stage_alert.triggered_stage3 = bool(int(val))
                elif key == "plat":
                    parts = val.split(",")
                    if len(parts) >= 6:
                        
                        p_x = float(parts[0])
                        p_y = float(parts[1])
                        p_w = int(float(parts[2]))
                        p_h = int(float(parts[3]))
                        p_stat = parts[4]
                        p_boost = int(float(parts[5]))
                        loaded_platforms.append([p_x, p_y, p_w, p_h, p_stat, p_boost])
    except Exception as e:
        print(f"Error loading save file: {e}")
        return False
               
    if loaded_platforms:
        platforms = loaded_platforms
       
    falling_blocks.clear()
    boss_enemy = Enemy()
    stage2_enemy = Stage2Enemy()
    stage3_enemy = Stage3Enemy()
    return True

running = True
boss_enemy = Enemy()
stage2_enemy = Stage2Enemy()
stage3_enemy = Stage3Enemy()
falling_blocks = []
stage_alert = StageNotification()

while running:
    timer.tick(fps)
   
    # -------------------------------------------------------------
    # STATE 1: MAIN MENU
    # -------------------------------------------------------------
    if game_state == "MENU":
        screen.blit(menu_bg_img, (0, 0))
        if title_img:
            screen.blit(title_img, (width // 2 - 225, 40))
        else:
            fallback_text = title_font.render("Swampy Jumper", True, white)
            fallback_rect = fallback_text.get_rect(center=(width // 2, 150))
            screen.blit(fallback_text, fallback_rect)
       
        screen.blit(img_normal, (width // 2 - 75, 270))
      
        if draw_button("START GAME", 200, 460, 200, 50, dark_green, light_green):
            reset_game()
            game_state = "GAME"
            pygame.time.delay(150)
           
        if draw_button("LOAD GAME", 200, 530, 200, 50, blue, dark_blue):
            game_state = "LOAD_GAME"
            pygame.time.delay(150)
           
        if draw_button("SETTINGS", 200, 600, 200, 50, gray, black):
            game_state = "SETTINGS"
            pygame.time.delay(150)

        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                running = False

    # -------------------------------------------------------------
    # STATE 2: SETTINGS SUB-MENU
    # -------------------------------------------------------------
    elif game_state == "SETTINGS":
        screen.blit(menu_bg_img, (0, 0))
        info_text = title_font.render("Settings Menu", True, white)
        screen.blit(info_text, info_text.get_rect(center=(width // 2, 200)))
       
        desc_text = font.render("Configure game rules or options here.", True, white)
        screen.blit(desc_text, desc_text.get_rect(center=(width // 2, 350)))
       
        if draw_button("BACK TO MENU", 200, 500, 200, 50, red, orange):
            game_state = "MENU"
            pygame.time.delay(150)

        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                running = False

    # -------------------------------------------------------------
    # STATE 3: LOAD GAME SUB-MENU
    # -------------------------------------------------------------
    elif game_state == "LOAD_GAME":
        screen.blit(menu_bg_img, (0, 0))
        info_text = title_font.render("Saved Profile", True, white)
        screen.blit(info_text, info_text.get_rect(center=(width // 2, 180)))
       
        if os.path.exists("save_file.txt"):
            desc_text = font.render("Discovered an active safe profile!", True, gold)
            screen.blit(desc_text, desc_text.get_rect(center=(width // 2, 280)))
           
            if draw_button("LAUNCH SAVED RUN", 150, 360, 300, 50, dark_green, light_green):
                if load_game_session():
                    game_state = "GAME"
                else:
                    print("Could not load the game session.")
                pygame.time.delay(150)
        else:
            desc_text = font.render("No saved sessions discovered.", True, white)
            screen.blit(desc_text, desc_text.get_rect(center=(width // 2, 300)))
       
        if draw_button("BACK TO MENU", 150, 480, 300, 50, red, orange):
            game_state = "MENU"
            pygame.time.delay(150)

        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                running = False

    # -------------------------------------------------------------
    # STATE 4: THE MAIN ACTIVE GAME CYCLE
    # -------------------------------------------------------------
    elif game_state == "GAME":
        stage_alert.update()

        # Render background scene layout
        if score >= 150:
            screen.blit(bg_stage3_img, (0, 0))
            stage_alert.trigger(3)
        elif score >= 70:
            screen.blit(bg_stage2_img, (0, 0))
            stage_alert.trigger(2)
        else:
            screen.blit(bg_img, (0, 0))
       
        score_text = font.render(f"Score: {score}", True, black if score < 150 else heavenly_blue)
        screen.blit(score_text, (10, 10))
       
        if draw_button("||", width - 60, 10, 50, 40, gray, red):
            game_state = "PAUSED"
            pygame.time.delay(150)
       
        if not stage_alert.active:
            # Enemy 1 Spawns between 20 and 70 pts
            if 20 <= score < 70:
                boss_enemy.update(falling_blocks)
                boss_enemy.draw(screen)
            # Enemy 2 Spawns at 90 pts, leaves at 150 pts
            if 90 <= score < 150:
                stage2_enemy.update(falling_blocks)
                stage2_enemy.draw(screen)
            # Enemy 3 (Laser) Spawns at 160 pts
            if score >= 160:
                stage3_enemy.update(falling_blocks)
                stage3_enemy.draw(screen)
           
        if score >= 70 and not projectiles_cleared_at_70:
            falling_blocks.clear()
            projectiles_cleared_at_70 = True
        if score >= 150 and not projectiles_cleared_at_150:
            falling_blocks.clear()
            projectiles_cleared_at_150 = True
       
        if not stage_alert.active:
            if is_boosting:
                screen.blit(img_boosting_visual, (X, Y + 25))
            elif is_crouching:
                screen.blit(img_squished, (X, Y + 25))
            else:
                screen.blit(img_normal, (X, Y))
           
        blocks = []
        for i in range(len(platforms)):
            if not stage_alert.active:
                if platforms[i][4] == "intact":
                    if score >= 150:
                        screen.blit(platform_stage3_img, (platforms[i][0], platforms[i][1]))
                    elif score >= 70:
                        screen.blit(platform_stage2_img, (platforms[i][0], platforms[i][1]))
                    else:
                        screen.blit(platform_img, (platforms[i][0], platforms[i][1]))
                   
                    if len(platforms[i]) > 5 and platforms[i][5] != -1:
                        b_x = platforms[i][0] + platforms[i][5]
                        b_y = platforms[i][1] + 15 - BOOSTER_H  
                        pygame.draw.rect(screen, light_green, (b_x, b_y, BOOSTER_W, BOOSTER_H), border_radius=3)
                        pygame.draw.rect(screen, gold, (b_x + 5, b_y + 3, BOOSTER_W - 10, BOOSTER_H - 6), border_radius=2)
                else:
                    if score >= 150:
                        screen.blit(broken_platform_stage3_img, (platforms[i][0], platforms[i][1]))
                    elif score >= 70:
                        screen.blit(broken_platform_stage2_img, (platforms[i][0], platforms[i][1]))
                    else:
                        screen.blit(broken_platform_img, (platforms[i][0], platforms[i][1]))
               
            block = pygame.Rect(platforms[i][0], platforms[i][1] + 15, platforms[i][2], 25)
            blocks.append(block)

        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                running = False
               
        keys = pygame.key.get_pressed()
        x_change = 0
        if keys[pygame.K_a] or keys[pygame.K_LEFT]:
            x_change = -player_speed
        if keys[pygame.K_d] or keys[pygame.K_RIGHT]:
            x_change = player_speed
                   
        if not stage_alert.active:
            X += x_change
        if X < -75: X = width
        elif X > width: X = -75
       
        if not stage_alert.active:
            jump = check_collision(blocks, jump)      
       
        if score >= 150:
            auto_scroll_speed = 3
        elif score >= 70:
            auto_scroll_speed = 2
        else:
            auto_scroll_speed = 1
       
        if not stage_alert.active:
            Y += auto_scroll_speed
            Y = update_player(Y)
       
        if Y < 400 and y_change < 0:
            Y = 400
           
        if not stage_alert.active:
            platforms = update_platforms(platforms, Y, y_change)
           
        player_rect = pygame.Rect(X + 45, Y + 30, 60, 95)  
        projectiles_to_remove = []
       
        for projectile in falling_blocks:
            if not stage_alert.active:
                projectile.update(auto_scroll_speed, y_change)
                projectile.draw(screen)
            proj_rect = pygame.Rect(projectile.x, projectile.y, projectile.size, projectile.size)
           
            for platform in platforms:
                if platform[4] == "intact":
                    plat_rect = pygame.Rect(platform[0], platform[1] + 15, platform[2], 25)
                    if proj_rect.colliderect(plat_rect):
                        if not stage_alert.active:
                            platform[4] = "broken"  
                            if len(platform) > 5:
                                platform[5] = -1
                        projectiles_to_remove.append(projectile)
                        break
           
            if proj_rect.colliderect(player_rect) and not is_boosting:
                game_state = "GAME_OVER"
                if score > high_score:
                    high_score = score
                pygame.time.delay(150)

        for p in projectiles_to_remove:
            if p in falling_blocks:
                falling_blocks.remove(p)

        if stage_alert.active:
            stage_alert.draw(screen)

        if Y > height:
            game_state = "GAME_OVER"
            if score > high_score:
                high_score = score
            pygame.time.delay(150)

    # -------------------------------------------------------------
    # STATE 5: PAUSE GAME MENU WINDOW
    # -------------------------------------------------------------
    elif game_state == "PAUSED":
        screen.blit(menu_bg_img, (0, 0))
        pause_text = title_font.render("Game Paused", True, white)
        screen.blit(pause_text, pause_text.get_rect(center=(width // 2, 180)))

        if draw_button("RESUME", 175, 290, 250, 50, dark_green, light_green):
            game_state = "GAME"
            pygame.time.delay(150)

        if draw_button("SAVE PROGRESS", 175, 360, 250, 50, blue, dark_blue):
            save_game_session()
            print("Session saved successfully!")
            game_state = "GAME"  
            pygame.time.delay(150)

        if draw_button("EXIT TO MENU", 175, 430, 250, 50, red, orange):
            game_state = "MENU"
            pygame.time.delay(150)

        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                running = False

    # -------------------------------------------------------------
    # STATE 6: GAME OVER SUMMARY WINDOW
    # -------------------------------------------------------------
    elif game_state == "GAME_OVER":
        screen.blit(menu_bg_img, (0, 0))
        go_text = title_font.render("GAME OVER", True, red)
        screen.blit(go_text, go_text.get_rect(center=(width // 2, 180)))

        score_res = font.render(f"Final Score reached: {score}", True, black)
        screen.blit(score_res, score_res.get_rect(center=(width // 2, 260)))

        high_res = font.render(f"Personal Best Record: {high_score}", True, dark_blue)
        screen.blit(high_res, high_res.get_rect(center=(width // 2, 310)))

        if draw_button("RETRY RUN", 175, 420, 250, 50, dark_green, light_green):
            reset_game()
            game_state = "GAME"
            pygame.time.delay(150)

        if draw_button("EXIT TO MENU", 175, 490, 250, 50, gray, black):
            game_state = "MENU"
            pygame.time.delay(150)

        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                running = False

    pygame.display.flip()

pygame.quit()
