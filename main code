class StageNotification:
    def __init__(self):
        self.active = False
        self.triggered_stage2 = False
        self.triggered_stage3 = False
        self.current_stage_context = 2
        self.alpha = 0
        self.timer = 0
        self.current_text = ""
        self.current_sub = ""
        self.segment_duration = 170
        self.fade_duration = 35
        self.hold_duration = 100

    def trigger(self, stage_number):
        if stage_number == 2 and not self.triggered_stage2:
            self.active = True
            self.triggered_stage2 = True
            self.current_stage_context = 2
            self.timer = 0
            self.alpha = 0
        elif stage_number == 3 and not self.triggered_stage3:
            self.active = True
            self.triggered_stage3 = True
            self.current_stage_context = 3
            self.timer = 0
            self.alpha = 0

    def update(self):
        if not self.active:
            return

        self.timer += 1

        if self.current_stage_context == 2:
            if self.timer <= self.segment_duration:
                self.current_text = "STAGE 2"
                self.current_sub = "WARNING: VOLCANIC ZONE AHEAD"
                local_frame = self.timer
            elif self.timer <= self.segment_duration * 2:
                self.current_text = "ARE YOU READY?"
                self.current_sub = "PREPARE YOURSELF"
                local_frame = self.timer - self.segment_duration
            elif self.timer <= self.segment_duration * 3:
                self.current_text = "IT IS GETTING HOT"
                self.current_sub = "TEMPERATURE RISING SURFACING NOW"
                local_frame = self.timer - (self.segment_duration * 2)
            else:
                self.active = False
                self.alpha = 0
                return
        else:
            if self.timer <= self.segment_duration:
                self.current_text = "STAGE 3"
                self.current_sub = "THE SKY IS BLEEDING"
                local_frame = self.timer
            elif self.timer <= self.segment_duration * 2:
                self.current_text = "READY TO FACE YOUR SINS?"
                self.current_sub = "THERE IS NO ESCAPE"
                local_frame = self.timer - self.segment_duration
            elif self.timer <= self.segment_duration * 3:
                self.current_text = "HA HA HA HA..."
                self.current_sub = "THE ARCHITECT LAUGHS"
                local_frame = self.timer - (self.segment_duration * 2)
            elif self.timer <= self.segment_duration * 4:
                self.current_text = "THEN BE PREPARED"
                self.current_sub = "FOR THE END OF ALL THINGS"
                local_frame = self.timer - (self.segment_duration * 3)
            elif self.timer <= self.segment_duration * 5:
                self.current_text = "JUDGEMENT TIME HAS COME"
                self.current_sub = "ACCEPT YOUR FATE"
                local_frame = self.timer - (self.segment_duration * 4)
            else:
                self.active = False
                self.alpha = 0
                return

        if local_frame <= self.fade_duration:
            self.alpha = int((local_frame / self.fade_duration) * 255)
        elif local_frame <= self.fade_duration + self.hold_duration:
            self.alpha = 255
        else:
            elapsed_out = local_frame - (self.fade_duration + self.hold_duration)
            self.alpha = int(255 - ((elapsed_out / self.fade_duration) * 255))
            if self.alpha < 0: self.alpha = 0

    def draw(self, surface):
        if not self.active:
            return

        banner_w, banner_h = 550, 200
        overlay = pygame.Surface((banner_w, banner_h), pygame.SRCALPHA)
        
        box_color = (20, 10, 5, 230) if self.current_stage_context == 2 else (10, 0, 0, 245)
        border_color = volcanic_lava if self.current_stage_context == 2 else deep_crimson
       
        pygame.draw.rect(overlay, box_color, (0, 0, banner_w, banner_h), border_radius=18)
        pygame.draw.rect(overlay, border_color, (0, 0, banner_w, banner_h), width=4, border_radius=18)

        text_main = volcanic_font_main.render(self.current_text, True, border_color)
        text_sub = volcanic_font_sub.render(self.current_sub, True, gold)

        main_rect = text_main.get_rect(center=(banner_w // 2, banner_h // 2 - 15))
        sub_rect = text_sub.get_rect(center=(banner_w // 2, banner_h // 2 + 45))

        overlay.blit(text_main, main_rect)
        overlay.blit(text_sub, sub_rect)

        overlay.set_alpha(self.alpha)
        surface.blit(overlay, (width // 2 - banner_w // 2, height // 3 - banner_h // 2))

    def reset(self):
        self.active = False
        self.triggered_stage2 = False
        self.triggered_stage3 = False
        self.alpha = 0
        self.timer = 0


class Enemy:
    def __init__(self):
        self.width = 80
        self.height = 40
        self.x = random.randint(0, width - self.width)
        self.y = 40  
        self.speed = 4
        self.direction = 1  
        self.throw_cooldown = 100
       
        self.state = "MOVE"
        self.state_timer = random.randint(100, 200)
       
    def update(self, projectiles_list):
        self.state_timer -= 1
        if self.state_timer <= 0:
            if self.state == "MOVE":
                self.state = "PAUSE"
                self.state_timer = 70  
            else:
                self.state = "MOVE"
                self.state_timer = random.randint(100, 200)

        if self.state == "MOVE":
            self.x += self.speed * self.direction
            if self.x <= 0 or self.x >= width - self.width:
                self.direction *= -1
           
        if self.throw_cooldown > 0:
            self.throw_cooldown -= 1
        else:
            src_x = self.x + self.width // 2
            src_y = self.y + self.height // 2
            angle = math.radians(90)
            projectiles_list.append(Projectile(src_x, src_y, angle, stage_type=1))
            self.throw_cooldown = random.randint(240, 360)  

    def draw(self, surface):
        surface.blit(enemy_stage1_img, (self.x, self.y))


